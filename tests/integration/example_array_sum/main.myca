proc uninitialized'T() -> T {}

proc array_sum'(let N: usize)(arr: ^[N]i32) -> i32
{
	let mut sum: i32 = 0;
	let mut i: usize = 0;
	while i < N
	{
		sum := sum + arr^[i];
		i := i + 1;
	}

	return sum;
}

proc main() -> i32
{
	let mut a: [5]i32 = uninitialized();
	a[0] := 1;
	a[1] := 2;
	a[2] := 3;
	a[3] := 4;
	a[4] := 5;

	let mut b: [3]i32 = uninitialized();
	b[0] := 23;
	b[1] := 42;
	b[2] := 9;

	return array_sum(&a) + array_sum(&b); // 15 + 74 = 89
}

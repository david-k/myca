//!test: negative_in_arg

//!error: |_:14| error: Array count has invalid type: Incompatible types usize and $KnownInt(-2,-2)
proc foo(a: [-2]i32) {}


//!-------------------------------------------------------------------
//!test: negative_in_let

proc uninitialized'T() -> T {}
proc foo()
{
	//!error: |_:10| error: Array count has invalid type: Incompatible types usize and $KnownInt(-3,-3)
	let a: [-3]i32 = uninitialized();
}


//!-------------------------------------------------------------------
//!test: negative_in_union

//!error: |_:22| error: Array count has invalid type: Incompatible types usize and $KnownInt(-1,-1)
typealias U = i32 | [-1]i32;


//!-------------------------------------------------------------------
//!test: non_const_in_let

proc uninitialized'T() -> T {}
proc main() -> i32
{
	let c: usize = 5;
	//!error: |_:12| error: Expected constant expression
	let arr: [c]usize = uninitialized();
}


//!-------------------------------------------------------------------
//!test: zero_in_union

//!error: |_:22| error: Array count must be strictly larger that zero
typealias U = i32 | [0]i32;


//!-------------------------------------------------------------------
//!test: zero_in_member

struct S
{
	//!error: |_:6| error: Array count must be strictly larger that zero
	m: [0]i32,
}


//!-------------------------------------------------------------------
//!test: zero_in_arg

//!error: |_:14| error: Array count must be strictly larger that zero
proc bar(a: [0]i32) {}


//!-------------------------------------------------------------------
//!test: zero_in_return

//!error: |_:16| error: Array count must be strictly larger that zero
proc foo() -> [0]i32 {}


//!-------------------------------------------------------------------
//!test: zero_in_let

proc uninitialized'T() -> T {}
proc main() -> i32
{
	//!error: |_:12| error: Array count must be strictly larger that zero
	let arr: [0]i32 = uninitialized();
}


//!-------------------------------------------------------------------
//!test: zero_in_generic_proc_arg

proc foo'T() -> T {}
proc main() -> i32
{
	//!error: |_:8| error: Array count must be strictly larger that zero
	foo'([0]i32)();
}


//!-------------------------------------------------------------------
//!test: zero_in_generic_struct_arg

struct S'T {}
proc main() -> i32
{
	//!error: |_:14| error: Array count must be strictly larger that zero
	let s = S'([0]i32)();
}
